<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Width="320" Height="180"
AllowsTransparency="True"
Background="Transparent"
WindowStyle="None">
    <Grid>
        <Border Margin="8"
                Padding="8"
                Background="#D91F1F1F"
                CornerRadius="6">
            <StackPanel>
                <TextBlock Text="Today's Schedule"
                           Foreground="White"
                           FontSize="12"
                           FontWeight="Bold"
                           Margin="0,0,0,6"/>
                <TextBlock Name="DailyPreviewText"
                           Text="No upcoming events."
                           Foreground="White"
                           FontFamily="Consolas"
                           FontSize="11"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
    <Window.TaskbarItemInfo>
         <TaskbarItemInfo>
          <TaskbarItemInfo.ThumbButtonInfos>
            <ThumbButtonInfoCollection/>
          </TaskbarItemInfo.ThumbButtonInfos>
         </TaskbarItemInfo>
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <DataTemplate x:Key="OverlayIcon">
            <Grid Width="{Binding IconSize}" Height="{Binding IconSize}">
                <Rectangle Fill="{Binding Color}"
                            Stroke="{Binding TextColor}"
                            StrokeThickness="{Binding LineWidth}"
                            RadiusX="4"
                            RadiusY="4"/>
    
                <TextBlock Text="{Binding Text}"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{Binding TextColor}"
                            FontWeight="Bold"
                            Height="{Binding IconSize}"
                            FontSize="{Binding FontSize}">
                </TextBlock>
            </Grid>
        </DataTemplate>
    </Window.Resources>
</Window>
