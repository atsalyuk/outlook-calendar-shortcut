<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Width="320" Height="180"
AllowsTransparency="True"
Background="Transparent"
WindowStyle="None">
    <Grid>
        <Border Padding="10"
                Background="#E6222222"
                CornerRadius="4">
            <StackPanel>
                <TextBlock Text="&#128197; Today"
                           Foreground="#90CAF9"
                           FontSize="13"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4"/>
                <Border Height="1" Background="#33FFFFFF" Margin="0,0,0,6"/>
                <TextBlock Name="DailyPreviewText"
                           Text="No upcoming events"
                           Foreground="#DDFFFFFF"
                           FontFamily="Segoe UI"
                           FontSize="11.5"
                           LineHeight="18"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
    <Window.TaskbarItemInfo>
         <TaskbarItemInfo>
          <TaskbarItemInfo.ThumbButtonInfos>
            <ThumbButtonInfoCollection/>
          </TaskbarItemInfo.ThumbButtonInfos>
         </TaskbarItemInfo>
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <DataTemplate x:Key="OverlayIcon">
            <Grid Width="{Binding IconSize}" Height="{Binding IconSize}">
                <Rectangle Fill="{Binding Color}"
                            Stroke="{Binding TextColor}"
                            StrokeThickness="{Binding LineWidth}"
                            RadiusX="4"
                            RadiusY="4"/>
    
                <TextBlock Text="{Binding Text}"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{Binding TextColor}"
                            FontWeight="Bold"
                            Height="{Binding IconSize}"
                            FontSize="{Binding FontSize}">
                </TextBlock>
            </Grid>
        </DataTemplate>
    </Window.Resources>
</Window>
