<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Width="320" Height="180"
AllowsTransparency="True"
Background="Transparent"
WindowStyle="None">
    <Grid>
        <Border Padding="12,10,12,10"
                Background="#E6222222"
                CornerRadius="6">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Name="HeaderDayText"
                               Text="TODAY"
                               Foreground="White"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               FontWeight="Bold"/>
                    <TextBlock Name="HeaderDateText"
                               Text=""
                               Foreground="#99FFFFFF"
                               FontFamily="Segoe UI"
                               FontSize="13"
                               Margin="8,0,0,0"/>
                </StackPanel>
                <Border Height="1" Background="#33FFFFFF" Margin="0,0,0,8"/>
                <TextBlock Name="DailyPreviewText"
                           Text="No upcoming events"
                           Foreground="#BBFFFFFF"
                           FontFamily="Segoe UI"
                           FontSize="11.5"
                           LineHeight="17"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>
    </Grid>
    <Window.TaskbarItemInfo>
         <TaskbarItemInfo>
          <TaskbarItemInfo.ThumbButtonInfos>
            <ThumbButtonInfoCollection/>
          </TaskbarItemInfo.ThumbButtonInfos>
         </TaskbarItemInfo>
    </Window.TaskbarItemInfo>
    <Window.Resources>
        <DataTemplate x:Key="OverlayIcon">
            <Grid Width="{Binding IconSize}" Height="{Binding IconSize}">
                <Rectangle Fill="{Binding Color}"
                            Stroke="{Binding TextColor}"
                            StrokeThickness="{Binding LineWidth}"
                            RadiusX="4"
                            RadiusY="4"/>
    
                <TextBlock Text="{Binding Text}"
                            TextAlignment="Center"
                            VerticalAlignment="Center"
                            Foreground="{Binding TextColor}"
                            FontWeight="Bold"
                            Height="{Binding IconSize}"
                            FontSize="{Binding FontSize}">
                </TextBlock>
            </Grid>
        </DataTemplate>
    </Window.Resources>
</Window>
